{
	"reload_command": "reload config",
	"starting_mode": "root mode",
	"enable_systray": true,
	"modes": {
		"::import test": {
			"banned_strings": ["thank you"],
			"aliases": {
				"^write\\((.*)\\)$": "script(copy;;\\1) + ctrl + shift + v"
			},
			"commands": {
				"open terminal": "alt + enter"
			}
		},
		"root mode": {
			"type": "vosk",
			"path": "models/vosk-model-small-en-us-0.15",
			"icon": [0, 255, 0],
			"input_delay": 0.01,
			"imports": ["::import test"],
			"commands": {
				"press {any}": "{1}",
				"{numeric} times press {any} ": "{1}({2})",
				"open firefox": "exec(firefox)",
				"text command": "python(print('Test command.'))",
				"test plus": "write(\\+)"
				"hold control": "hold(ctrl)",
				"release control": "release(ctrl)",
				"toggle shift": "toggle(shift)"
			}
		},
		"dictate mode": {
			"type": "transformer",
			"model_name": "whisper-turbo",
			"icon": [255, 0, 0],
			"silence_seconds": 0.3,
			"max_chunk_seconds": 30.0,
			"energy_threshold": 0.01,
			"pre_roll_seconds": 0.25,
			"lang": "en",
			"input_delay": 0.01,
			"transformer_device": "auto",
			"imports": ["::import test"],
			"commands": {
				"{rest}": "write({1})"
			}
		}
	}
}
